# Google Gemini API key for LLM-driven song list generation.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Absolute path to the yt-dlp executable. If omitted, the binary on PATH is used.
YT_DLP_PATH=

# Absolute path to the ffmpeg executable. If omitted, the binary on PATH is used.
FFMPEG_PATH=

# Target integrated loudness for downloaded mp3s (EBU R128 loudnorm filter).
# Accepted range: -70 to -5. Leave blank to skip normalization.
# Common targets: -14 (Spotify/YouTube), -16 (Apple Music), -23 (broadcast).
MP3_NORMALIZE_LUFS=-14
